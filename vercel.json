{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 60,
            "includeFiles": "{api/**,utils/**,*.png,*.txt}"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ]
}

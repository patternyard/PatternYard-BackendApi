{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 60,
            "includeFiles": "{api/**,utils/**,*.png,*.txt}"
        }
    },
    "redirects": [
        {
            "source": "/",
            "destination": "https://patternyard.dev",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/:path*",
            "destination": "/api/index"
        }
    ]
}
